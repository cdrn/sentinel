# RPC endpoints (WebSocket) — only set the chains you want to monitor
ETH_RPC_WS=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_RPC_WS=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_WS=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Feature flags (true/false — all default to true)
ENABLE_DEPLOYMENT_LISTENER=true
ENABLE_FACTORY_LISTENER=true
ENABLE_VULN_DETECTORS=true
ENABLE_SNIPER=true
ENABLE_EXECUTOR=true

# Executor
EXECUTOR_PRIVATE_KEY=0x...
EXECUTOR_LIVE=false

# Telegram alerts
TG_BOT_TOKEN=
TG_CHAT_ID=

# Database (defaults to ./backdraft.db)
DB_PATH=

# Flashbots (ETH mainnet, future)
FLASHBOTS_AUTH_KEY=
